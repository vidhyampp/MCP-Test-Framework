# LLM provider used by the ai/ modules (self-healing, visual triage, fuzzing, etc.)
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-5

# Target under test. Defaults (config/environments.yaml) point at the bundled
# examples/demo_server.py so tests/mcp/ pass out of the box — override these
# to test your real server. "python" resolves to the interpreter running pytest.
MCP_SERVER_COMMAND=python
MCP_SERVER_ARGS=examples/demo_server.py
BASE_URL=http://localhost:3000

# Toggle AI features on/off without touching code
AI_SELF_HEALING_ENABLED=true
AI_VISUAL_TRIAGE_ENABLED=true
AI_FLAKY_ANALYSIS_ENABLED=true

# Reporting
HEADLESS=true
SCREENSHOT_ON_FAILURE=true
